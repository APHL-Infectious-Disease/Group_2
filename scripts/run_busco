ASSEMBLY=$1
SAMPLE=$2

OUTPUT="results/$SAMPLE/busco"
MODE="geno"
DATASETS_VERSION="odb12"
LINEAGE="gammaproteobacteria_odb12"
CPUS=$(nproc --all)

apptainer exec docker://staphb/busco busco --out $OUTPUT --mode $MODE --datasets_version $DATASETS_VERSION --lineage_dataset $LINEAGE --in $ASSEMBLY --cpu $CPUS --opt-out-run-stats
