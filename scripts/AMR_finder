#!/usr/bin/env bash
set -euo pipefail

ASSEMBLY=$1        
SAMPLE=$2          
ORGANISM=$3  

OUTPUT="results/$SAMPLE/amrfinderplus"
IDENT_MIN="${IDENT_MIN:-0.9}"
COV_MIN="${COV_MIN:-0.5}"
TRANSLATION_TABLE="${TRANSLATION_TABLE:-11}"
THREADS=$(nproc --all)

mkdir -p "$OUTPUT"

apptainer exec docker://staphb/amrfinderplus amrfinder \
  --nucleotide "$ASSEMBLY" \
  --output "$OUTPUT/${SAMPLE}.amrfinderplus.tsv" \
  --threads "$THREADS" \
  --ident_min "$IDENT_MIN" \
  --coverage_min "$COV_MIN" \
  --translation_table "$TRANSLATION_TABLE" \
  --plus \
  --organism "$ORGANISM" \
  > "$OUTPUT/${SAMPLE}.amrfinderplus.log" 2>&1

if ! $found_any; then
  echo "No assembly files found in ${ASSEMBLY_DIR}"
  exit 1
fi

echo "AMRFinderPlus complete. Results in ${OUT_DIR}"

